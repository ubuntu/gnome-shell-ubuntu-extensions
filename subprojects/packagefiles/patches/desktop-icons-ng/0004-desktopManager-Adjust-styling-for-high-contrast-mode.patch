From cacad6b4fcfe28177b55bacd6e0cf14077c92015 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Marco=20Trevisan=20=28Trevi=C3=B1o=29?= <mail@3v1n0.net>
Date: Mon, 23 Mar 2026 19:17:33 +0100
Subject: [PATCH 4/4] desktopManager: Adjust styling for high-contrast mode

---
 app/desktopManager.js | 17 +++++++++++------
 app/enums.js          |  1 +
 app/preferences.js    |  5 +++++
 3 files changed, 17 insertions(+), 6 deletions(-)

diff --git a/app/desktopManager.js b/app/desktopManager.js
index 8c758aa..d38e564 100644
--- a/app/desktopManager.js
+++ b/app/desktopManager.js
@@ -130,6 +130,7 @@ var DesktopManager = class {
                 });
             }
         }
+        Prefs.a11YInterface?.connect('changed::high-contrast', () => this._setSelectionColor());
         this._showHidden = Prefs.gtkSettings.get_boolean('show-hidden');
         this.showDropPlace = Prefs.desktopSettings.get_boolean('show-drop-place');
         this.useNemo = Prefs.desktopSettings.get_boolean('use-nemo');
@@ -430,21 +431,25 @@ var DesktopManager = class {
 
     _setSelectionColor() {
         this.selectColor = this._styleContext.get_color(Gtk.StateFlags.NORMAL);
-        const darkMode = Prefs.schemaGnomeInterface?.get_string('color-scheme') === 'prefer-dark';
+        const highContrast = !!Prefs.a11YInterface?.get_boolean('high-contrast');
+        // FIXME: In Gtk3 there's no such thing as dark mode and high contrast,
+        // so we consider it always light if high contrast is set.
+        // This can change when gtk4 will be used.
+        const darkMode = !highContrast && Prefs.schemaGnomeInterface?.get_string('color-scheme') === 'prefer-dark';
         this.borderColor = darkMode ?
-            new Gdk.RGBA({red: 0, green: 0, blue: 0, alpha: 0.5}) :
-            new Gdk.RGBA({red: 1, green: 1, blue: 1, alpha: 0.5});
+            new Gdk.RGBA({red: 0, green: 0, blue: 0, alpha: highContrast ? 0.9 : 0.5}) :
+            new Gdk.RGBA({red: 1, green: 1, blue: 1, alpha: highContrast ? 0.9 : 0.5});
 
         let style = `.desktop-icons-selected {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.2);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, ${highContrast ? 0.7: 0.2});
             box-shadow: 0 0 0 1px rgba(${this.borderColor.red * 255},${this.borderColor.green * 255}, ${this.borderColor.blue * 255}, ${this.borderColor.alpha});
         }
         .desktop-icons-keyboard-selected {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.2);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, ${highContrast ? 0.7: 0.2});
             border-color: rgba(${this.borderColor.red * 255},${this.borderColor.green * 255},${this.borderColor.blue * 255}, ${this.borderColor.alpha});
         }
         .file-item-hover {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.15);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, ${highContrast ? 0.5 : 0.15});
         }`;
         this._cssProviderSelection.load_from_data(style);
         Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), this._cssProviderSelection, 600);
diff --git a/app/enums.js b/app/enums.js
index 92850db..e3c7c5b 100644
--- a/app/enums.js
+++ b/app/enums.js
@@ -105,6 +105,7 @@ var SCHEMA_NAUTILUS = 'org.gnome.nautilus.preferences';
 var SCHEMA_NAUTILUS_COMPRESSION = 'org.gnome.nautilus.compression';
 var SCHEMA_A11Y_KEYBOARD = 'org.gnome.desktop.a11y.keyboard';
 var SCHEMA_A11Y_APPLICATIONS = 'org.gnome.desktop.a11y.applications';
+var SCHEMA_A11Y_INTERFACE = 'org.gnome.desktop.a11y.interface';
 var SCHEMA_GTK = 'org.gtk.Settings.FileChooser';
 var SCHEMA = 'org.gnome.shell.extensions.ding';
 var SCHEMA_MUTTER = 'org.gnome.mutter';
diff --git a/app/preferences.js b/app/preferences.js
index c90db9c..a144bd1 100644
--- a/app/preferences.js
+++ b/app/preferences.js
@@ -36,6 +36,7 @@ var desktopSettings;
 var mutterSettings = null;
 var a11YKeyboard = null;
 var a11YApplications = null;
+var a11YInterface = null;
 // This is already in Nautilus settings, so it should not be made tweakable here
 var CLICK_POLICY_SINGLE = false;
 var prefsWindow;
@@ -74,6 +75,10 @@ function init(path) {
     if (schemaA11YApplications) {
         a11YApplications = new Gio.Settings({ settings_schema: schemaA11YApplications});
     }
+    const schemaA11YInterface = schemaSource.lookup(Enums.SCHEMA_A11Y_INTERFACE, true);
+    if (schemaA11YInterface) {
+        a11YInterface = new Gio.Settings({ settings_schema: schemaA11YInterface });
+    }
 
     desktopSettings = PrefsWindow.get_schema(path, Enums.SCHEMA);
     let schemaMutter = schemaSource.lookup(Enums.SCHEMA_MUTTER, true);
-- 
