From 1b44c01c38d4b46d400a11e84f833511f515b476 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Marco=20Trevisan=20=28Trevi=C3=B1o=29?= <mail@3v1n0.net>
Date: Mon, 23 Mar 2026 18:37:30 +0100
Subject: [PATCH 2/4] desktopManager: Adjust selection color based on dark mode

---
 app/desktopGrid.js    | 10 +++++-----
 app/desktopManager.js | 16 +++++++++++-----
 app/stylesheet.css    |  2 +-
 3 files changed, 17 insertions(+), 11 deletions(-)

diff --git a/app/desktopGrid.js b/app/desktopGrid.js
index 7449e82..073cbf2 100644
--- a/app/desktopGrid.js
+++ b/app/desktopGrid.js
@@ -394,13 +394,13 @@ var DesktopGrid = class extends SignalManager.SignalManager{
             })
             );
             cr.fill();
-            cr.setLineWidth(1);
+            cr.setLineWidth(2);
             this._roundedRectangle(cr, xInit + 0.5, yInit + 0.5, xFin - xInit, yFin - yInit, 10);
             Gdk.cairo_set_source_rgba(cr, new Gdk.RGBA({
-                red: this._desktopManager.selectColor.red,
-                green: this._desktopManager.selectColor.green,
-                blue: this._desktopManager.selectColor.blue,
-                alpha: 0.8,
+                red: this._desktopManager.borderColor.red,
+                green: this._desktopManager.borderColor.green,
+                blue: this._desktopManager.borderColor.blue,
+                alpha: this._desktopManager.borderColor.alpha,
             })
             );
             cr.stroke();
diff --git a/app/desktopManager.js b/app/desktopManager.js
index 4e5c259..b563d2a 100644
--- a/app/desktopManager.js
+++ b/app/desktopManager.js
@@ -127,6 +127,7 @@ var DesktopManager = class {
                 Prefs.schemaGnomeDarkSettings.connect('changed', (obj, key) => {
                     if (key === 'color-scheme') {
                         this._checkApplyDarkModeSetting();
+                        this._setSelectionColor();
                     }
                 });
             }
@@ -431,16 +432,21 @@ var DesktopManager = class {
 
     _setSelectionColor() {
         this.selectColor = this._styleContext.get_color(Gtk.StateFlags.NORMAL);
+        const darkMode = Prefs.schemaGnomeDarkSettings?.get_string('color-scheme') === 'prefer-dark';
+        this.borderColor = darkMode ?
+            new Gdk.RGBA({red: 0, green: 0, blue: 0, alpha: 0.5}) :
+            new Gdk.RGBA({red: 1, green: 1, blue: 1, alpha: 0.5});
+
         let style = `.desktop-icons-selected {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.3);
-            border-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.2);
+            box-shadow: 0 0 0 1px rgba(${this.borderColor.red * 255},${this.borderColor.green * 255}, ${this.borderColor.blue * 255}, ${this.borderColor.alpha});
         }
         .desktop-icons-keyboard-selected {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.3);
-            border-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.5);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.2);
+            border-color: rgba(${this.borderColor.red * 255},${this.borderColor.green * 255},${this.borderColor.blue * 255}, ${this.borderColor.alpha});
         }
         .file-item-hover {
-            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.1);
+            background-color: rgba(${this.selectColor.red * 255},${this.selectColor.green * 255}, ${this.selectColor.blue * 255}, 0.15);
         }`;
         this._cssProviderSelection.load_from_data(style);
         Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), this._cssProviderSelection, 600);
diff --git a/app/stylesheet.css b/app/stylesheet.css
index a761cc5..f7d7598 100644
--- a/app/stylesheet.css
+++ b/app/stylesheet.css
@@ -13,7 +13,7 @@
     border-radius: 10px;
     border-style: solid;
     border-width: 3px;
-    border-color: rgba(0, 0, 0, 0);
+    border-color: transparent;
 }
 
 .not-found {
-- 
