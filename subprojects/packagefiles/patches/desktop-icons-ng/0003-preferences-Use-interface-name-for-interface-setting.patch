From 5d94e379aa286031ee80d34db7c37879ca43ea11 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Marco=20Trevisan=20=28Trevi=C3=B1o=29?= <mail@3v1n0.net>
Date: Mon, 23 Mar 2026 19:01:01 +0100
Subject: [PATCH 3/4] preferences: Use interface name for interface settings

It's not just related to dark scheme
---
 app/desktopManager.js | 14 ++++++--------
 app/enums.js          |  2 +-
 app/preferences.js    |  6 +++---
 3 files changed, 10 insertions(+), 12 deletions(-)

diff --git a/app/desktopManager.js b/app/desktopManager.js
index b563d2a..8c758aa 100644
--- a/app/desktopManager.js
+++ b/app/desktopManager.js
@@ -122,13 +122,11 @@ var DesktopManager = class {
         this._monitorDesktopDir.connect('changed', (obj, file, otherFile, eventType) => this._updateDesktopIfChanged(file, otherFile, eventType));
 
         this.fileItemMenu = new FileItemMenu.FileItemMenu(this);
-        if (Prefs.schemaGnomeDarkSettings) {
+        if (Prefs.schemaGnomeInterface) {
             if (this._checkApplyDarkModeSetting()) {
-                Prefs.schemaGnomeDarkSettings.connect('changed', (obj, key) => {
-                    if (key === 'color-scheme') {
-                        this._checkApplyDarkModeSetting();
-                        this._setSelectionColor();
-                    }
+                Prefs.schemaGnomeInterface.connect('changed::color-scheme', (obj, key) => {
+                    this._checkApplyDarkModeSetting();
+                    this._setSelectionColor();
                 });
             }
         }
@@ -432,7 +430,7 @@ var DesktopManager = class {
 
     _setSelectionColor() {
         this.selectColor = this._styleContext.get_color(Gtk.StateFlags.NORMAL);
-        const darkMode = Prefs.schemaGnomeDarkSettings?.get_string('color-scheme') === 'prefer-dark';
+        const darkMode = Prefs.schemaGnomeInterface?.get_string('color-scheme') === 'prefer-dark';
         this.borderColor = darkMode ?
             new Gdk.RGBA({red: 0, green: 0, blue: 0, alpha: 0.5}) :
             new Gdk.RGBA({red: 1, green: 1, blue: 1, alpha: 0.5});
@@ -455,7 +453,7 @@ var DesktopManager = class {
     _checkApplyDarkModeSetting() {
         try {
             let displayGtkSettings = Gtk.Settings.get_for_screen(Gdk.Screen.get_default());
-            displayGtkSettings.gtk_application_prefer_dark_theme = Prefs.schemaGnomeDarkSettings.get_string('color-scheme') === 'prefer-dark';
+            displayGtkSettings.gtk_application_prefer_dark_theme = Prefs.schemaGnomeInterface.get_string('color-scheme') === 'prefer-dark';
             return true;
         } catch (e) {
             return false;
diff --git a/app/enums.js b/app/enums.js
index 30b7720..92850db 100644
--- a/app/enums.js
+++ b/app/enums.js
@@ -110,7 +110,7 @@ var SCHEMA = 'org.gnome.shell.extensions.ding';
 var SCHEMA_MUTTER = 'org.gnome.mutter';
 var EXEC_KEY = 'exec';
 var NAUTILUS_SCRIPTS_DIR = '.local/share/nautilus/scripts';
-var SCHEMA_DARK_SETTINGS = 'org.gnome.desktop.interface';
+var SCHEMA_INTERFACE = 'org.gnome.desktop.interface';
 
 var S_IXUSR = 0o00100;
 var S_IWOTH = 0o00002;
diff --git a/app/preferences.js b/app/preferences.js
index b25e1f2..c90db9c 100644
--- a/app/preferences.js
+++ b/app/preferences.js
@@ -62,9 +62,9 @@ function init(path) {
     } else {
         nautilusCompression = new Gio.Settings({settings_schema: compressionSchema});
     }
-    const schemaDarkSettings = schemaSource.lookup(Enums.SCHEMA_DARK_SETTINGS, true);
-    if (schemaDarkSettings) {
-        this.schemaGnomeDarkSettings = new Gio.Settings({ settings_schema: schemaDarkSettings });
+    const schemaInterface = schemaSource.lookup(Enums.SCHEMA_INTERFACE, true);
+    if (schemaInterface) {
+        this.schemaGnomeInterface = new Gio.Settings({ settings_schema: schemaInterface});
     }
     const schemaA11YKeyboard = schemaSource.lookup(Enums.SCHEMA_A11Y_KEYBOARD, true);
     if (schemaA11YKeyboard) {
-- 
